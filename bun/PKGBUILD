provides=(bun)
makedepends=(cmake go esbuild)
source=(${pkgname}-${pkgver}.tar.gz::$url/archive/refs/tags/$pkgname-v$pkgver.tar.gz)
sha256sums=('e73227b65dd05a9f9244b3f15e68285bdb79ed09469a1d6d76c436f3426e360e')

prepare() {
  # fork https://github.com/Jarred-Sumner/zig
}

package() {
  cd "$srcdir/$pkgname-$pkgname-v$pkgver"

  npm install
  make release
}
